# Dev secrets — never commit
keys/
*.pem
.env
.env.*
!.env.example
!prana-portal/.env.production
!prana-mobile/.env

# Terraform — never commit state or real tfvars
terraform/**/*.tfstate
terraform/**/*.tfstate.backup
terraform/**/.terraform/
terraform/**/.terraform.lock.hcl
terraform/**/prod.tfvars
terraform/**/staging.tfvars
terraform/**/*.auto.tfvars
!terraform/**/*.tfvars.example

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# Node
node_modules/
dist/
.expo/
.next/

# Docker
*.log

# OS
.DS_Store
Thumbs.db

prana-api/uvicorn.err
prana-portal/vite.err

prana-api/uvicorn.err
prana-portal/vite.err
