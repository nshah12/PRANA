# Copy to .env for local development. Never commit .env.

APP_ENV=development
DEBUG=true

# YugabyteDB (local Docker)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=prana
DB_USER=yugabyte
DB_PASSWORD=yugabyte

# AWS KMS — use localstack or real credentials
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Dev-only HMAC secret — replaced by KMS in production
PLATFORM_HMAC_SECRET=dev_secret

# JWT keys — generate with: openssl genrsa -out keys/jwt_private.pem 2048
#             then:          openssl rsa -in keys/jwt_private.pem -pubout -out keys/jwt_public.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem

# Redis
REDIS_URL=redis://localhost:6379/0

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=prana-dev

# S3 (localstack or real)
S3_BUCKET_DOCUMENTS=prana-documents-dev
S3_BUCKET_STAGING=prana-staging-dev

# Internal services
AI_SERVICE_URL=http://localhost:8001
ASK_SERVICE_URL=http://localhost:8002

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
